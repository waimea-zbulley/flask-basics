{% extends "pages/_base.jinja" %}

{% block content %}

<h1>List of Cats</h1>

<p>The list below comes from data passed in...</p>

<ul>

    {% for cat in cats %}
        
        <li>{{ cat.name }} has id: {{ cat.id }}</li>
        <a href="/cat/{{ cat.id }}">Profile</a>
    {% endfor %}

</ul>

{% endblock %}